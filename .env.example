DATABASE_URL=postgres://postgres:postgres@localhost:5432/arksey

# Network Rail public data feeds account.
OPENRAIL_USERNAME=you@example.com
OPENRAIL_PASSWORD=replace-me

# Target crossing location.
TARGET_TIPLOC=ARKSEYL
# Train Movement messages use STANOX rather than TIPLOC. Set this once known,
# or populate tiploc_location.stanox for ARKSEYL before starting live ingestion.
TARGET_STANOX=

# STOMP live feeds.
OPENRAIL_STOMP_HOST=publicdatafeeds.networkrail.co.uk
OPENRAIL_STOMP_PORT=61618
OPENRAIL_STOMP_TOPICS=TRAIN_MVT_ALL_TOC,VSTP_ALL
OPENRAIL_STOMP_CLIENT_ID=arksey-level-crossing
OPENRAIL_STOMP_DURABLE=true

# Daily SCHEDULE import. JSON full extract is available from around 06:00.
SCHEDULE_DAILY_TIME=06:15
SCHEDULE_TIMEZONE=Europe/London
SCHEDULE_LOOKAHEAD_DAYS=3
SCHEDULE_TYPE=CIF_ALL_FULL_DAILY
SCHEDULE_DAY=toc-full
SCHEDULE_IMPORT_ON_START=false
